# PostgreSQL connection string (Neon, Supabase, or local Postgres)
# Example (Neon):  postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/chess?sslmode=require
# Example (local): postgresql://postgres:postgres@localhost:5432/chess_tournament?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chess_tournament?schema=public"

# Secret used to sign admin session JWTs. Generate one with:
#   openssl rand -base64 32
JWT_SECRET="replace-this-with-a-long-random-string"

# Seed / bootstrap admin account (used by prisma/seed.ts)
ADMIN_EMAIL="admin@chessmaster.dev"
ADMIN_PASSWORD="ChessAdmin!123"

APP_NAME="Chessmaster Tournament Manager"
PORT=5173
